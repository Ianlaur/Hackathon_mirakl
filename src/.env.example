DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"
HACKATHON_USER_ID="00000000-0000-0000-0000-000000000001"

# Optional: n8n webhook URL called on leave event creation. See docs/n8n-setup.md
N8N_WEBHOOK_URL=""

# Dust low-stock agent webhook integration
DUST_AGENT_WEBHOOK_URL="https://your-dust-or-orchestrator-webhook.example.com/low-stock"
DUST_AGENT_API_KEY=""

# OpenAI API key used by Mira (mascot chat, tool calling, Whisper transcription)
OPENAI_API_KEY=""
MIRA_MODEL="gpt-4o"

# Supabase Realtime for browser (decision_ledger stream on /activity + dashboard).
# Find these in Supabase → Project Settings → API. The anon key is safe to expose client-side.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Dust orchestrator agent integration (copilot chat)
DUST_ORCHESTRATOR_AGENT_ID=""
DUST_ORCHESTRATOR_WEBHOOK_URL="https://your-dust-webhook.example.com/orchestrator"
DUST_ORCHESTRATOR_API_KEY=""

# Shopify app integration
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_APP_URL="http://localhost:3000"
SHOPIFY_SCOPES="read_orders,read_products,read_inventory"
SHOPIFY_API_VERSION="2025-01"
