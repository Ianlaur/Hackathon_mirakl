{
  "name": "laurtools-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "db:push": "prisma db push --accept-data-loss",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:prepare": "prisma db execute --file scripts/create-users-view.sql --schema prisma/schema.prisma && prisma db execute --file scripts/create-email-logs.sql --schema prisma/schema.prisma",
    "db:prepare:low-stock": "prisma db execute --file scripts/create-low-stock-trigger.sql --schema prisma/schema.prisma",
    "dust:test:low-stock": "node scripts/test-dust-low-stock-agent.js",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "prisma:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts"
  },
  "dependencies": {
